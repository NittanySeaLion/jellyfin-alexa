# Internal address of your Jellyfin server, reachable from wherever this container runs
# (e.g. the Docker network on your NAS, or its LAN IP). This is a direct server-to-server
# call, NOT through your Cloudflare Tunnel -- use plain http:// and the internal address.
JELLYFIN_URL=http://192.168.x.x:8096

# Jellyfin API key: Dashboard > API Keys > "+" to create one for this skill.
JELLYFIN_API_KEY=replace-with-your-jellyfin-api-key

# Jellyfin user id whose library/permissions this skill searches and streams as.
# Dashboard > Users > click the user > the id is in the page URL.
JELLYFIN_USER_ID=replace-with-your-jellyfin-user-id

# Port this service listens on inside its container.
PORT=3000
